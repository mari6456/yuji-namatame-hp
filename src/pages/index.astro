<header id="top" class="yj-hero" style="position:relative;min-height:46vh;display:flex;align-items:flex-end;overflow:hidden;background:#0c0c10;border-top:1px solid var(--border-subtle)">
  <img src="/uploads/IMG_3149.JPG" alt="Yuji Namatame ドラム演奏" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block">
  <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(8,8,12,.55) 0%,rgba(8,8,12,.05) 26%,rgba(8,8,12,.12) 52%,rgba(8,8,12,.82) 100%)"></div>
