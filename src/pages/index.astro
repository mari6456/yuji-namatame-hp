    <h1 class="zk yj-hero-h" style="margin:0;font-weight:700;font-size:64px;line-height:1.26;letter-spacing:-.01em;color:#fff;max-width:15em;text-wrap:balance;text-shadow:0 2px 40px rgba(0,0,0,.4)">Yuji Namatame<span style="display:block;font-size:0.3em;font-weight:600;letter-spacing:.22em;color:rgba(255,255,255,.82);margin-top:.7em">OFFICIAL SITE</span></h1>
