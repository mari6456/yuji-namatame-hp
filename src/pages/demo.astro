<style is:global>
/* ===== Design tokens (YUJI design system, inlined for a self-contained site) ===== */
:root{
  /* Neutrals */
  --white:#ffffff; --black:#000000;
  --gray-50:#f5f5f7; --gray-100:#ececee; --gray-150:#e3e3e6; --gray-200:#d7d7dc;
  --gray-300:#c3c3ca; --gray-400:#a2a2ab; --gray-500:#7d7d86; --gray-600:#5c5c64;
  --gray-700:#3f3f46; --gray-800:#26262b; --gray-900:#161618; --ink:#1d1d1f;
  /* Brand cobalt */
  --blue-50:#eef2ff; --blue-100:#dbe3ff; --blue-200:#b8c8ff; --blue-400:#4d75ff;
  --blue-500:#1b53ff; --blue-600:#123fe0; --blue-700:#0f34b8;
  --red-500:#dc3838;
  /* Semantic aliases */
  --text-link:var(--blue-500);
  --surface-hover:var(--gray-100);
  --surface-glass:rgba(255,255,255,0.72);
  --border-subtle:#ededf0; --border-default:var(--gray-200); --border-strong:var(--gray-300);
  --border-inverse:rgba(255,255,255,0.16);
  --accent:var(--blue-500); --accent-hover:var(--blue-600); --accent-pressed:var(--blue-700);
  /* Type */
  --font-sans:'Hanken Grotesk',-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;
  --font-mono:'Geist Mono',ui-monospace,'SF Mono',Menlo,Consolas,monospace;
  /* Layout */
  --container-sm:720px; --container-md:980px; --container-lg:1200px; --gutter:24px;
  /* Radius */
  --radius-xs:6px; --radius-sm:10px; --radius-md:14px; --radius-lg:20px; --radius-xl:28px; --radius-pill:999px;
  /* Elevation */
  --shadow-sm:0 1px 2px rgba(20,20,30,0.06),0 2px 6px rgba(20,20,30,0.05);
  --shadow-md:0 2px 6px rgba(20,20,30,0.06),0 8px 20px rgba(20,20,30,0.07);
  --shadow-lg:0 4px 12px rgba(20,20,30,0.07),0 18px 44px rgba(20,20,30,0.10);
  --shadow-accent:0 6px 18px rgba(27,83,255,0.28);
  /* Motion */
  --ease-standard:cubic-bezier(0.4,0.0,0.2,1);
  --ease-out:cubic-bezier(0.16,1,0.3,1);
  --duration-fast:120ms;
}

*,*::before,*::after{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;font-family:'Hanken Grotesk','Zen Kaku Gothic New',sans-serif;color:var(--ink);background:#fff;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
a{color:inherit;text-decoration:none}
img{max-width:100%}
.eb{font-size:17px;font-weight:700;letter-spacing:.22em}
.zk{font-family:'Zen Kaku Gothic New',sans-serif}
@keyframes yjIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}

/* ===== Interaction states (converted from the design's style-hover attributes) ===== */
a{transition:background var(--duration-fast) var(--ease-standard),color var(--duration-fast) var(--ease-standard),box-shadow var(--duration-fast) var(--ease-standard)}
.hv-nav-cta:hover{background:var(--accent-hover)}
.hv-accent-btn:hover{background:var(--accent-hover);box-shadow:var(--shadow-accent)}
.hv-glass-light:hover{background:rgba(255,255,255,.2)}
.hv-glass-dark:hover{background:rgba(255,255,255,.14)}
.hv-ink-btn:hover{background:#000}
.hv-link-accent:hover{color:var(--accent-hover)}
.hv-chip:hover{background:var(--surface-hover)}
.hv-email:hover{color:#fff}
.yj-flyer:hover img{transform:scale(1.035)}
.yj-flyer img{transition:transform .5s var(--ease-out)}

/* ===== Contact form ===== */
.yj-field{display:flex;flex-direction:column;gap:8px;font-size:12.5px;font-weight:600;letter-spacing:.02em;color:var(--gray-300);text-align:left}
.yj-field input,.yj-field select,.yj-field textarea{font-family:inherit;font-size:15px;font-weight:400;letter-spacing:0;color:var(--ink);background:#fff;border:1px solid transparent;border-radius:var(--radius-sm);padding:13px 15px;width:100%}
.yj-field textarea{resize:vertical;min-height:124px;line-height:1.7}
.yj-field input:focus,.yj-field select:focus,.yj-field textarea:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(27,83,255,.35)}
.yj-field input::placeholder,.yj-field textarea::placeholder{color:var(--gray-400)}

/* ===== Schedule "MORE" toggle (no-JS <details>) ===== */
.yj-sched-more>summary{list-style:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;height:48px;margin-top:22px;border-radius:var(--radius-pill);background:var(--gray-50);color:var(--gray-700);font-size:13.5px;font-weight:600;letter-spacing:.04em;box-shadow:inset 0 0 0 1px var(--border-default);transition:background var(--duration-fast) var(--ease-standard)}
.yj-sched-more>summary::-webkit-details-marker{display:none}
.yj-sched-more>summary:hover{background:var(--gray-100)}
.yj-sched-more[open]>summary{margin-top:0;border-top:1px solid var(--border-subtle);border-radius:0;background:transparent;box-shadow:none;color:var(--gray-500)}
.yj-sched-more[open]>summary:hover{background:var(--surface-hover)}
.yj-sched-more>summary .yj-more-open{display:none}
.yj-sched-more[open]>summary .yj-more-close{display:none}
.yj-sched-more[open]>summary .yj-more-open{display:inline}
.yj-more-chev{transition:transform var(--duration-fast) var(--ease-standard)}
.yj-sched-more[open]>summary .yj-more-chev{transform:rotate(180deg)}
/* per-event "詳しく見る" detail toggle */
.yj-ev{border-top:1px solid var(--border-subtle)}
.yj-ev>summary{list-style:none;cursor:pointer;display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;padding:14px 0}
.yj-ev>summary::-webkit-details-marker{display:none}
.yj-ev-toggle{display:inline-flex;align-items:center;gap:6px;height:34px;padding:0 14px;border-radius:var(--radius-pill);font-size:13px;font-weight:600;color:var(--gray-700);box-shadow:inset 0 0 0 1px var(--border-default);white-space:nowrap;transition:color var(--duration-fast) var(--ease-standard),box-shadow var(--duration-fast) var(--ease-standard)}
.yj-ev[open] .yj-ev-toggle{color:var(--accent);box-shadow:inset 0 0 0 1px var(--accent)}
.yj-ev .yj-ev-labelclose{display:none}
.yj-ev[open] .yj-ev-labelmore{display:none}
.yj-ev[open] .yj-ev-labelclose{display:inline}
.yj-ev[open] .yj-more-chev{transform:rotate(180deg)}
.yj-ev-body{padding:2px 0 22px}

/* ===== Mobile hamburger nav ===== */
.yj-nav-toggle{position:absolute;width:1px;height:1px;opacity:0;pointer-events:none}
.yj-burger{display:none;align-items:center;justify-content:center;width:42px;height:42px;border:0;background:transparent;color:var(--ink);cursor:pointer;border-radius:var(--radius-sm)}
.yj-burger:hover{background:var(--surface-hover)}
.yj-burger .ic-close{display:none}

@media(max-width:860px){
 .yj-burger{display:inline-flex;margin-right:-8px}
 #nv-links{display:none!important;position:absolute;top:64px;left:0;right:0;flex-direction:column!important;align-items:stretch!important;gap:0!important;background:var(--surface-glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);border-bottom:1px solid var(--border-subtle);box-shadow:var(--shadow-md);padding:6px 24px 16px}
 .yj-nav-toggle:checked ~ #nv-links{display:flex!important}
 .yj-nav-toggle:checked ~ .yj-burger .ic-menu{display:none}
 .yj-nav-toggle:checked ~ .yj-burger .ic-close{display:block}
 #nv-links>a{padding:15px 2px;border-top:1px solid var(--border-subtle);font-size:15px}
 #nv-links>a:first-child{border-top:0}
 #nv-links>a.hv-nav-cta{margin-top:12px;justify-content:center;height:48px;border-radius:var(--radius-pill);border-top:0}
 .yj-hero-br{display:none!important}
 .yj-pad{padding-left:24px!important;padding-right:24px!important}
 .yj-hero-h{font-size:38px!important}
 .yj-hero{min-height:42vh!important}
 .yj-hero-inner{padding-bottom:44px!important}
 .yj-h2{font-size:30px!important}
 .yj-2col{grid-template-columns:1fr!important;gap:36px!important}
 .yj-3col{grid-template-columns:1fr!important;gap:40px 0!important}
 .yj-2list{grid-template-columns:1fr!important;gap:0!important}
 .yj-band{height:320px!important}
 .yj-heroband{height:340px!important}
 .yj-sec{padding-top:72px!important;padding-bottom:72px!important}
 .yj-ctas{flex-direction:column!important}
 .yj-ctas>*{width:100%!important;justify-content:center!important}
 /* schedule rows: stack date on its own line, give title full width */
 .yj-sched>div,.yj-sched-more>div,.yj-ev>summary{grid-template-columns:1fr auto!important;gap:6px 14px!important;align-items:center!important}
 .yj-sched>div>div:first-child,.yj-sched-more>div>div:first-child,.yj-ev>summary>div:first-child{grid-column:1/-1!important;text-align:left!important;font-size:13px!important}
 .yj-sched>div>div:first-child span,.yj-sched-more>div>div:first-child span,.yj-ev>summary>div:first-child span{display:inline!important;margin-left:8px!important}
}

/* ===== DEMO: warm accent override ===== */
:root{--accent:#c65a24;--accent-hover:#a94a1c;--accent-pressed:#8a3c15;--text-link:#c65a24;--shadow-accent:0 6px 18px rgba(198,90,36,.28);--blue-200:#f2c9ad;--blue-400:#e0955f}
</style>
</head>
<body>

<div style="width:100%;overflow-x:clip;background:#fff">
<div style="background:#1d1d1f;color:#fff;text-align:center;font-size:12.5px;line-height:1.6;padding:9px 16px">🎸 このページはサイトテンプレート「Musician Site Builder」の<b>デモ</b>です。人物・公演・作品はすべて架空のサンプルです。</div>

<nav style="position:sticky;top:0;z-index:50;height:64px;display:flex;align-items:center;justify-content:space-between;padding:0 48px;background:var(--surface-glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);border-bottom:1px solid var(--border-subtle)" class="yj-pad">
  <a href="#top" class="zk" style="font-weight:700;font-size:18px;letter-spacing:.04em;color:var(--ink)">studio Otowa</a>
  <input type="checkbox" id="nav-toggle" class="yj-nav-toggle" aria-hidden="true">
  <label for="nav-toggle" class="yj-burger" aria-label="メニュー">
    <svg class="ic-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M3 12h18"></path><path d="M3 18h18"></path></svg>
    <svg class="ic-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6 18 18"></path><path d="M18 6 6 18"></path></svg>
  </label>
  <div id="nv-links" style="display:flex;gap:30px;align-items:center">
    <a href="#schedule" style="font-size:14px;font-weight:500;color:var(--gray-700)">スケジュール</a>
    <a href="#media" style="font-size:14px;font-weight:500;color:var(--gray-700)">メディア</a>
    <a href="#services" style="font-size:14px;font-weight:500;color:var(--gray-700)">サービス</a>
    <a href="#profile" style="font-size:14px;font-weight:500;color:var(--gray-700)">プロフィール</a>
    <a href="#fanclub" style="font-size:14px;font-weight:500;color:var(--gray-700)">ファンクラブ</a>
    <a href="#contact" class="hv-nav-cta" style="display:inline-flex;align-items:center;height:38px;padding:0 18px;border-radius:var(--radius-pill);background:var(--accent);color:#fff;font-size:14px;font-weight:600">お問い合わせ</a>
  </div>
</nav>

<header id="top" class="yj-hero" style="position:relative;min-height:46vh;display:flex;align-items:flex-end;overflow:hidden;background:radial-gradient(130% 130% at 82% 12%, #3a2113 0%, #16100c 55%, #0c0c10 100%);border-top:1px solid var(--border-subtle)">
    <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(8,8,12,.55) 0%,rgba(8,8,12,.05) 26%,rgba(8,8,12,.12) 52%,rgba(8,8,12,.82) 100%)"></div>
  <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(8,8,12,.5) 0%,rgba(8,8,12,0) 58%)"></div>
  <div class="yj-pad yj-hero-inner" style="position:relative;width:100%;max-width:var(--container-lg);margin:0 auto;padding:0 48px 64px;animation:yjIn .85s var(--ease-out) both">
    <h1 class="zk yj-hero-h" style="margin:0;font-weight:700;font-size:64px;line-height:1.26;letter-spacing:-.01em;color:#fff;max-width:15em;text-wrap:balance;text-shadow:0 2px 40px rgba(0,0,0,.4)">Kanade Otowa<span style="display:block;font-size:0.3em;font-weight:600;letter-spacing:.22em;color:rgba(255,255,255,.82);margin-top:.7em">OFFICIAL SITE</span></h1>
  </div>
</header>


<section id="schedule" class="yj-sec yj-pad" style="padding:84px 48px;scroll-margin-top:72px">
  <div style="margin-bottom:36px">
    <div class="eb" style="color:var(--accent)">SCHEDULE</div>
  </div>

  <!-- スケジュールは Googleスプレッドシート（ウェブに公開したCSV）から /schedule.js が自動描画します。
       行の追加・編集はシート側で行ってください。data-src を差し替えるとシートを変更できます。 -->
  <div class="yj-sched"><div style="display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;padding:14px 0;border-top:1px solid var(--border-subtle)"><div style="font-family:var(--font-mono);font-size:15px;font-weight:500;color:var(--accent);white-space:nowrap;text-align:center">2026.08.10<span style="display:block;font-size:11px;color:var(--gray-400)">MON</span></div><div><div class="zk" style="font-weight:700;font-size:17px;line-height:1.45;color:var(--ink)">Otowa Acoustic Night vol.12</div><div style="margin-top:3px;font-size:13px;color:var(--gray-500)">下北沢サンプルホール（東京）</div></div><span class="yj-ev-toggle" style="cursor:default">詳細</span></div><div style="display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;padding:14px 0;border-top:1px solid var(--border-subtle)"><div style="font-family:var(--font-mono);font-size:15px;font-weight:500;color:var(--accent);white-space:nowrap;text-align:center">2026.08.24<span style="display:block;font-size:11px;color:var(--gray-400)">MON</span></div><div><div class="zk" style="font-weight:700;font-size:17px;line-height:1.45;color:var(--ink)">夏の弾き語りツアー「音の葉」</div><div style="margin-top:3px;font-size:13px;color:var(--gray-500)">名古屋サンプルスタジオ ／ OPEN 18:00</div></div><span class="yj-ev-toggle" style="cursor:default">詳細</span></div><div style="display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;padding:14px 0;border-top:1px solid var(--border-subtle)"><div style="font-family:var(--font-mono);font-size:15px;font-weight:500;color:var(--accent);white-space:nowrap;text-align:center">2026.09.05<span style="display:block;font-size:11px;color:var(--gray-400)">SAT</span></div><div><div class="zk" style="font-weight:700;font-size:17px;line-height:1.45;color:var(--ink)">サンプルバンド レコ発ライブ（Gtサポート）</div><div style="margin-top:3px;font-size:13px;color:var(--gray-500)">梅田デモライブハウス（大阪）</div></div><span class="yj-ev-toggle" style="cursor:default">詳細</span></div><div style="display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;padding:14px 0;border-top:1px solid var(--border-subtle)"><div style="font-family:var(--font-mono);font-size:15px;font-weight:500;color:var(--accent);white-space:nowrap;text-align:center">2026.10.03<span style="display:block;font-size:11px;color:var(--gray-400)">SAT</span></div><div><div class="zk" style="font-weight:700;font-size:17px;line-height:1.45;color:var(--ink)">Otowa Guitar Workshop #4</div><div style="margin-top:3px;font-size:13px;color:var(--gray-500)">オンライン開催（Zoom）</div></div><span class="yj-ev-toggle" style="cursor:default">詳細</span></div></div>
  <p style="margin:14px 0 0;font-size:12px;color:var(--gray-400)">※ 実際のサイトでは、Googleフォームから送信するだけでこの一覧が自動更新されます（過去の公演は自動で非表示）。</p>
  <p style="margin:20px 0 0;font-size:12.5px;line-height:1.8;color:var(--gray-400)">※ 開演時間・チケット情報などの詳細は各公演の公式ページをご確認ください。</p>
</section>

<section id="media" class="yj-sec yj-pad" style="padding:104px 48px;background:var(--gray-50);border-top:1px solid var(--border-subtle);scroll-margin-top:72px">
  <div style="margin-bottom:40px">
    <div class="eb" style="color:var(--accent)">MEDIA</div>
  </div>
  <div class="yj-2col" style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:28px 28px">
    <div>
      <div style="position:relative;aspect-ratio:16/9;border-radius:var(--radius-md);overflow:hidden;background:#000;box-shadow:var(--shadow-sm)">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:#1c1c20;color:#8a8a92"><svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="m10 8 6 4-6 4z"></path></svg><span style="font-size:12.5px">YouTube動画が入ります</span></div>
      </div>
      <p style="margin:14px 0 0;font-size:14.5px;font-weight:600;line-height:1.6;color:var(--ink)">「音の葉」Official Music Video<span style="display:block;margin-top:3px;font-weight:500;font-size:12.5px;color:var(--gray-500)">Kanade Otowa 1st Digital Single</span></p>
    </div>
    <div>
      <div style="position:relative;aspect-ratio:16/9;border-radius:var(--radius-md);overflow:hidden;background:#000;box-shadow:var(--shadow-sm)">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:#1c1c20;color:#8a8a92"><svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="m10 8 6 4-6 4z"></path></svg><span style="font-size:12.5px">YouTube動画が入ります</span></div>
      </div>
      <p style="margin:14px 0 0;font-size:14.5px;font-weight:600;line-height:1.6;color:var(--ink)">Acoustic Session Live<span style="display:block;margin-top:3px;font-weight:500;font-size:12.5px;color:var(--gray-500)">studio Otowa セッション映像</span></p>
    </div>
    <div>
      <div style="position:relative;aspect-ratio:16/9;border-radius:var(--radius-md);overflow:hidden;background:#000;box-shadow:var(--shadow-sm)">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:#1c1c20;color:#8a8a92"><svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="m10 8 6 4-6 4z"></path></svg><span style="font-size:12.5px">YouTube動画が入ります</span></div>
      </div>
      <p style="margin:14px 0 0;font-size:14.5px;font-weight:600;line-height:1.6;color:var(--ink)">ギターアレンジ解説 vol.3<span style="display:block;margin-top:3px;font-weight:500;font-size:12.5px;color:var(--gray-500)">フィンガーピッキング入門</span></p>
    </div>
